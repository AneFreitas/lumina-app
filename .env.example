# ==============================
# LUMINA - Exemplo de variáveis
# ==============================
# Copie este arquivo para .env.local e preencha apenas no seu ambiente local.

# --- Frontend (Vite) ---
# URL do seu backend que fará a chamada segura para TTS (sem expor chave no app)
VITE_TTS_API_BASE_URL=http://localhost:3001

# Liga/desliga uso de TTS via backend
VITE_USE_BACKEND_TTS=false

# Voz Google Cloud usada pelo frontend ao chamar seu backend
VITE_TTS_VOICE_NAME=pt-BR-Neural2-B

# Firebase Web (frontend)
VITE_FIREBASE_API_KEY=SUA_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=SEU_PROJETO.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=SEU_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=SEU_PROJETO.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=SEU_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=SEU_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=SEU_MEASUREMENT_ID

# --- Backend (NÃO usar direto no frontend) ---
# Se você tiver um backend no mesmo ambiente local, mantenha essas chaves lá.
GOOGLE_CLOUD_PROJECT_ID=SEU_PROJECT_ID
GOOGLE_TTS_API_KEY=SUA_API_KEY
GOOGLE_TTS_VOICE_NAME=pt-BR-Neural2-B
GOOGLE_TTS_AUDIO_ENCODING=MP3
GEMINI_API_KEY=SUA_GEMINI_API_KEY
